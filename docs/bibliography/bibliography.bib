@misc{nobre_endfb-viii1_2025,
	title = {{ENDF}/{B}-{VIII}.1: {Updated} {Nuclear} {Reaction} {Data} {Library} for {Science} and {Applications}},
	shorttitle = {{ENDF}/{B}-{VIII}.1},
	url = {http://arxiv.org/abs/2511.03564},
	doi = {10.48550/arXiv.2511.03564},
	abstract = {The ENDF/B-VIII.1 library is the newest recommended evaluated nuclear data file by the Cross Section Evaluation Working Group (CSEWG) for use in nuclear science and technology applications, and incorporates advances made in the six years since the release of ENDF/B-VIII.0. Among key advances made are that the \${\textasciicircum}\{239\}\$Pu file was reevaluated by a joint international effort and that updated \${\textasciicircum}\{16,18\}\$O, \${\textasciicircum}\{19\}\$F, \${\textasciicircum}\{28-30\}\$Si, \${\textasciicircum}\{50-54\}\$Cr, \${\textasciicircum}\{55\}\$Mn, \${\textasciicircum}\{54,56,57\}\$Fe, \${\textasciicircum}\{63,65\}\$Cu, \${\textasciicircum}\{139\}\$La, \${\textasciicircum}\{233,235,238\}\$U, and \${\textasciicircum}\{240,241\}\$Pu neutron nuclear data from the IAEA coordinated INDEN collaboration were adopted. Over 60 neutron dosimetry cross sections were adopted from the IAEA's IRDFF-II library. In addition, the new library includes significant changes for \${\textasciicircum}3\$He, \${\textasciicircum}6\$Li,\${\textasciicircum}9\$Be, \${\textasciicircum}\{51\}\$V, \${\textasciicircum}\{88\}\$Sr, \${\textasciicircum}\{103\}\$Rh, \${\textasciicircum}\{140,142\}\$Ce, Dy, \${\textasciicircum}\{181\}\$Ta, Pt, \${\textasciicircum}\{206-208\}\$Pb, and \${\textasciicircum}\{234,236\}\$U neutron data, and new nuclear data for the photonuclear, charged-particle and atomic sublibraries. Numerous thermal neutron scattering kernels were reevaluated or provided for the very first time. On the covariance side, work was undertaken to introduce better uncertainty quantification standards and testing for nuclear data covariances. The significant effort to reevaluate important nuclides has reduced bias in the simulations of many integral experiments with particular progress noted for fluorine, copper, and stainless steel containing benchmarks. Data issues hindered the successful deployment of the previous ENDF/B-VIII.0 for commercial nuclear power applications in high burnup situations. These issues were addressed by improving the \${\textasciicircum}\{238\}\$U and \${\textasciicircum}\{239,240,241\}\$Pu evaluated data in the resonance region. The new library performance as a function of burnup is similar to the reference ENDF/B-VII.1 library. The ENDF/B-VIII.1 data are available in ENDF-6 and GNDS format at https://doi.org/10.11578/endf/2571019.},
	language = {en},
	urldate = {2026-03-15},
	publisher = {arXiv},
	author = {Nobre, G. P. A. and Capote, R. and Pigni, M. T. and Trkov, A. and Mattoon, C. M. and Neudecker, D. and Brown, D. A. and Chadwick, M. B. and Kahler, A. C. and Kleedtke, N. A. and Zerkle, M. and Hawari, A. I. and Chapman, C. W. and Fleming, N. C. and Wormald, J. L. and Ramić, K. and Danon, Y. and Gibson, N. A. and Brain, P. and Paris, M. W. and Hale, G. M. and Thompson, I. J. and Barry, D. P. and Stetcu, I. and Haeck, W. and Lovell, A. E. and Mumpower, M. R. and Potel, G. and Kravvaris, K. and Noguere, G. and McDonnell, J. D. and Carlson, A. D. and Dunn, M. and Kawano, T. and Wiarda, D. and Al-Qasir, I. and Arbanas, G. and Arcilla, R. and Beck, B. and Bernard, D. and Beyer, R. and Brown, J. M. and Cabellos, O. and Casperson, R. J. and Cheng, Y. and Chimanski, E. V. and Coles, R. and Cornock, M. and Cotchen, J. and Crozier, J. P. W. and Cullen, D. E. and Daskalakis, A. and Descalle, M.-A. and DiJulio, D. D. and Dimitriou, P. and Dreyfuss, A. C. and Durán, I. and Ferrer, R. and Gaines, T. and Gillette, V. and Gert, G. and Guber, K. H. and Haverkamp, J. D. and Herman, M. W. and Holmes, J. and Hursin, M. and Jisrawi, N. and Junghans, A. R. and Kelly, K. J. and Kim, H. I. and Kim, K. S. and Koning, A. J. and Koštál, M. and Laramee, B. K. and Lauer-Coles, A. and Leal, L. and Lee, H. Y. and Lewis, A. M. and Malec, J. and Damián, J. I. Márquez and Marshall, W. J. and Mattera, A. and Muhrer, G. and Ney, A. and Ormand, W. E. and Parsons, D. K. and Percher, C. M. and Pronyaev, V. G. and Qteish, A. and Quaglioni, S. and Rapp, M. and Ressler, J. J. and Rising, M. and Rochman, D. and Romano, P. K. and Roubtsov, D. and Schnabel, G. and Schulc, M. and Siemers, G. J. and Sonzogni, A. A. and Talou, P. and Thompson, J. and Trumbull, T. H. and Marck, S. C. van der and Vorabbi, M. and Wemple, C. and Wendt, K. A. and White, M. and Wright, R. Q.},
	month = nov,
